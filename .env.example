# Database Configuration
# Ensure the user has permissions for both clbc_main and clbc_audit
DB_USER=cladmin
DB_PASSWORD=your_database_password_here
DB_HOST=127.0.0.1
DB_DATABASE=clbc_main

# JWT Configuration
# A secure 256-bit base64 encoded key is required.
# Generate one using: openssl rand -base64 32
JWT_SECRET=your_secure_jwt_secret_here
